{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/socitix/stx-skills/stx-feature/wave-state.schema.json",
  "title": "wave-state.json",
  "description": "Canonical state for one /stx-feature wave. HTML artifacts are rendered from this file.",
  "type": "object",
  "required": ["wave_id", "wave_slug", "status", "initial_request", "features", "config", "persona_versions"],
  "properties": {
    "wave_id": {
      "type": "string",
      "description": "Format: wave-<slug>-<4-char-random>",
      "pattern": "^wave-[a-z0-9-]+-[a-z0-9]{4}$"
    },
    "wave_slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "status": {
      "enum": ["planning", "gate-1", "gate-2", "gate-3", "dev-wave", "done", "halted-at-cap", "blocked"]
    },
    "initial_request": { "type": "string" },
    "config": {
      "type": "object",
      "required": ["soft_cap", "hard_cap", "suspicious_ceiling", "max_parallel_devs", "continue_past_dry_run", "vitest_install_allowed", "use_browser_mcp", "commit_policy"],
      "properties": {
        "soft_cap": { "type": "integer", "minimum": 1 },
        "hard_cap": { "type": "integer", "minimum": 1 },
        "suspicious_ceiling": { "type": "integer", "minimum": 1 },
        "max_parallel_devs": { "type": "integer", "minimum": 1 },
        "continue_past_dry_run": { "type": "boolean" },
        "vitest_install_allowed": { "type": "boolean" },
        "use_browser_mcp": { "type": "boolean" },
        "commit_policy": { "enum": ["no-commit", "commit-after-green", "commit-and-pr"] }
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Frozen at Gate 2. Seed (from interview) + Analyst additions + Architect additions."
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "actor", "acceptance_criteria", "tasks", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^F[0-9]+$" },
          "title": { "type": "string" },
          "actor": { "type": "string" },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "existing_system_impact": { "type": "string" },
          "out_of_scope": { "type": "array", "items": { "type": "string" } },
          "status": { "enum": ["todo", "in-progress", "done", "halted"] },
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "tier", "scope_paths", "depends_on", "status"],
              "properties": {
                "id": { "type": "string", "pattern": "^F[0-9]+-T[0-9]+$" },
                "title": { "type": "string" },
                "tier": { "enum": ["db", "service", "api", "ui"] },
                "scope_paths": { "type": "array", "items": { "type": "string" } },
                "depends_on": { "type": "array", "items": { "type": "string" } },
                "acceptance_test_hint": { "type": "string" },
                "existing_patterns_to_follow": { "type": "array", "items": { "type": "string" } },
                "test_path": { "type": ["string", "null"] },
                "test_kind": { "enum": ["playwright", "e2e", "vitest-unit", null] },
                "status": { "enum": ["todo", "in-progress", "done", "halted", "skipped", "paused"] },
                "iterations_used": { "type": "integer", "minimum": 0 },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "suspicious": {
      "type": "array",
      "description": "Real-time append-only log of scope drift, test-file touches, mocks-of-SUT, and unrelated build breaks.",
      "items": {
        "type": "object",
        "required": ["at", "task_id", "kind", "description", "resolution"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "task_id": { "type": "string" },
          "dev_id": { "type": "string", "description": "Agent run identifier" },
          "kind": { "enum": ["scope-drift", "test-file-touch", "mock-of-sut", "build-break", "out-of-scope"] },
          "description": { "type": "string" },
          "resolution": { "enum": ["resolved", "accepted", "open", "halted"] }
        }
      }
    },
    "escalations": {
      "type": "array",
      "description": "Each soft-cap trip that re-engaged the Architect.",
      "items": {
        "type": "object",
        "required": ["n", "task_id", "at", "trigger"],
        "properties": {
          "n": { "type": "integer", "minimum": 1 },
          "task_id": { "type": "string" },
          "at": { "type": "string", "format": "date-time" },
          "trigger": { "enum": ["soft-cap-hit", "suspicious-ceiling", "qa-pause", "reviewer-halt"] },
          "architect_summary": { "type": "string" }
        }
      }
    },
    "reviewer_verdicts": {
      "type": "array",
      "description": "Append-only log of Reviewer verdicts. One entry per Reviewer spawn (one per Dev hand-back). Feeds Wave 3 metrics — rejection rate per tier, most-common concern kind, concerns that persist past iteration 2.",
      "items": {
        "type": "object",
        "required": ["task_id", "iteration", "at", "approved", "verdict"],
        "properties": {
          "task_id": { "type": "string", "pattern": "^F[0-9]+-T[0-9]+$" },
          "iteration": { "type": "integer", "minimum": 1, "description": "Iteration counter for this task at the time of review." },
          "at": { "type": "string", "format": "date-time" },
          "approved": { "type": "boolean" },
          "verdict": { "enum": ["approved", "concerns", "test-file-edit-detected", "assertion-weakened", "sut-mocked"] },
          "diff_summary": {
            "type": "object",
            "properties": {
              "files_in_scope": { "type": "array", "items": { "type": "string" } },
              "files_out_of_scope": { "type": "array", "items": { "type": "string" } },
              "lines_added": { "type": "integer", "minimum": 0 },
              "lines_removed": { "type": "integer", "minimum": 0 }
            }
          },
          "concerns": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["kind", "summary", "severity"],
              "properties": {
                "kind": { "enum": ["scope-drift", "pattern-divergence", "result-shape", "typing", "smallest-change", "comment-debt", "error-handling", "smell", "out-of-scope-frozen"] },
                "file": { "type": "string" },
                "line": { "type": "integer" },
                "summary": { "type": "string" },
                "severity": { "enum": ["high", "medium", "low"] }
              }
            }
          },
          "suggested_revisions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "files_touched": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "add", "del"],
        "properties": {
          "path": { "type": "string" },
          "add": { "type": "integer" },
          "del": { "type": "integer" }
        }
      }
    },
    "agents_spawned": {
      "type": "object",
      "description": "Counts by role for the result.html summary.",
      "properties": {
        "analyst": { "type": "integer" },
        "architect": { "type": "integer" },
        "qa": { "type": "integer" },
        "reviewer": { "type": "integer" },
        "dev": { "type": "integer" }
      }
    },
    "persona_versions": {
      "type": "object",
      "description": "Snapshot of .claude/agents/*.md version fields at wave start. Locks the wave to a specific persona generation for reproducibility and cross-wave metric aggregation.",
      "required": ["analyst", "architect", "qa", "reviewer", "dev_base", "dev_tier_db", "dev_tier_service", "dev_tier_api", "dev_tier_ui"],
      "properties": {
        "analyst": { "type": "string", "description": "Version of .claude/agents/stx-analyst.md" },
        "architect": { "type": "string", "description": "Version of .claude/agents/stx-architect.md" },
        "qa": { "type": "string", "description": "Version of .claude/agents/stx-qa.md" },
        "reviewer": { "type": "string", "description": "Version of .claude/agents/stx-reviewer.md" },
        "dev_base": { "type": "string", "description": "Version of .claude/agents/stx-dev-base.md" },
        "dev_tier_db": { "type": "string", "description": "Version of .claude/agents/stx-dev-tier-db.md" },
        "dev_tier_service": { "type": "string", "description": "Version of .claude/agents/stx-dev-tier-service.md" },
        "dev_tier_api": { "type": "string", "description": "Version of .claude/agents/stx-dev-tier-api.md" },
        "dev_tier_ui": { "type": "string", "description": "Version of .claude/agents/stx-dev-tier-ui.md" }
      }
    }
  }
}
