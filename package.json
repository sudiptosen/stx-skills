{
  "name": "stx-skills",
  "version": "1.6.0",
  "description": "Organization-wide Claude Code skills collection",
  "main": "dist/cli/install.js",
  "bin": {
    "stx-skills": "./dist/cli/install.js",
    "stx-checkin": "./dist/skills/stx-checkin.js",
    "stx-pr-merge": "./dist/skills/stx-pr-merge.js",
    "stx-image": "./dist/skills/stx-image.js",
    "stx-report": "./dist/skills/stx-report.js"
  },
  "scripts": {
    "build": "tsc && npm run prepare-docs",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare-docs": "mkdir -p docs && cp .claude/skills/stx-help-html/help.html docs/index.html",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude-code",
    "skills",
    "git",
    "pr",
    "workflow",
    "images",
    "automation",
    "report",
    "worktree"
  ],
  "author": "STX",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    ".claude/skills"
  ]
}
